{
  "ConnectionStrings": {
    "FridayDb": "Host=localhost;Port=5432;Database=friday;Username=friday;Password=friday;Timeout=15",
    "AdminDatabase": "Host=localhost;Port=5432;Database=friday;Username=friday;Password=friday;Timeout=15",
    "Redis": "localhost:6379"
  },
  "Cache": {
    "UseRedis": false,
    "RedisConnectionString": "localhost:6379",
    "RedisInstanceName": "Friday:"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ApplyMigrationsOnStartup": false
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "Friday.API",
    "OtlpEndpoint": "",
    "LogExport": "Serilog"
  },
  "Admin": {
    "EffectivePermissionCache": {
      "GrantListTtlMinutes": 60
    }
  },
  "Authentication": {
    "AllowPublicRegistration": false,
    "DefaultUserRoleCode": "USER",
    "PasswordFlow": {
      "AppBaseUrl": "http://localhost:5173",
      "ResetPath": "/auth/reset-password",
      "ForceChangeTokenMinutes": 30,
      "ForgotPasswordTokenMinutes": 30
    },
    "OAuth2": {
      "DefaultRoleCode": "USER",
      "Providers": {
        "google": {
          "Enabled": false,
          "ClientId": "",
          "ClientSecret": "",
          "TokenEndpoint": "https://oauth2.googleapis.com/token",
          "UserInfoEndpoint": "https://openidconnect.googleapis.com/v1/userinfo",
          "Scope": "openid email profile",
          "SubjectField": "sub",
          "EmailField": "email",
          "NameField": "name"
        }
      }
    },
    "Jwt": {
      "Secret": "FridayDevJwtSecret_ChangeInProduction_Min32Chars!!",
      "Issuer": "Friday.API",
      "Audience": "Friday.Clients",
      "AccessTokenMinutes": 60,
      "RefreshTokenDays": 14
    }
  },
  "Integration": {
    "Email": {
      "Smtp": {
        "Enabled": false,
        "Host": "",
        "Port": 587,
        "EnableSsl": true,
        "Username": "",
        "Password": "",
        "FromAddress": "noreply@friday.local",
        "FromName": "Friday"
      }
    }
  },
  "Localization": {
    "CacheMinutes": 60
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread",
      "Serilog.Exceptions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId",
      "WithExceptionDetails"
    ],
    "GrafanaLoki": {
      "Enabled": false,
      "Uri": ""
    }
  },
  "SerilogClassic": {
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}
